{
    "name": "capell-app/capell-packages",
    "description": "Capell 4 Packages",
    "home": "https://capell.app",
    "type": "library",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "CACHE_STORE=array php ./vendor/bin/testbench package:discover --ansi"
        ],
        "rector": "rector",
        "lint": "pint --parallel",
        "analyze": "phpstan analyse --memory-limit=-1 --configuration=phpstan.neon",
        "prettier": "npx prettier --write \"packages/**/*.{css,js,yml,json,md,blade.php}\"",
        "eslint": "npx eslint 'packages/*/resources/js/**/*.js' --max-warnings=0",
        "preflight": [
            "@prettier",
            "@eslint",
            "@rector",
            "@lint",
            "@analyze"
        ],
        "coverage": "php -d memory_limit=-1 -d pcov.enabled=1 -d pcov.directory=. -d pcov.exclude='~vendor|tests|storage|bootstrap|.temp~' vendor/bin/pest --coverage --min=80 --colors=always --configuration=phpunit.xml",
        "coverage-report": "php -d memory_limit=-1 -d pcov.enabled=1 -d pcov.directory=. -d pcov.exclude='~vendor|tests|storage|bootstrap|.temp~' vendor/bin/pest --coverage --coverage-html=coverage --colors=always --configuration=phpunit.xml",
        "test:unit": "php -d memory_limit=-1 vendor/bin/pest --colors=always --parallel --configuration=phpunit.xml",
        "test": [
            "@test:unit"
        ],
        "clear": "CACHE_STORE=array php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "CACHE_STORE=array php vendor/bin/testbench package:discover --ansi",
        "build": "CACHE_STORE=array php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "CACHE_STORE=array php vendor/bin/testbench serve --ansi"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/admin"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/frontend"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-fileinfo": "*",
        "ext-intl": "*",
        "ext-simplexml": "*",
        "amidesfahani/filament-tinyeditor": "^4.0",
        "awcodes/filament-badgeable-column": "^3.0|^4.0",
        "awobaz/compoships": "^2.3",
        "bezhansalleh/filament-shield": "^4.1",
        "bkwld/cloner": "^3.11",
        "blade-ui-kit/blade-heroicons": "^2.5",
        "capell-app/admin": "^2.0",
        "capell-app/core": "^2.0",
        "capell-app/frontend": "^2.0",
        "codewithdennis/filament-select-tree": "^4.0",
        "cms-multi/filament-clear-cache": "^3.0",
        "croustibat/filament-jobs-monitor": "^4.4",
        "filament/filament": "^4.7|^5.2",
        "filament/spatie-laravel-media-library-plugin": "^4.0|^5.0",
        "filament/spatie-laravel-settings-plugin": "^4.0|^5.0",
        "filament/spatie-laravel-tags-plugin": "^4.0|^5.0",
        "guava/filament-icon-picker": "^3.0|^4.0",
        "guzzlehttp/guzzle": "^7.5",
        "howdu/filament-record-switcher": "^2.0",
        "icamys/php-sitemap-generator": "^4.4.1",
        "aimeos/laravel-nestedset": "^7.0",
        "lara-zeus/spatie-translatable": "^1.0|^2.0",
        "laravel/framework": "^11.44.2|^12.0",
        "laravel/prompts": "^0.2|^0.3",
        "livewire/blaze": "^1.0",
        "lorisleiva/laravel-actions": "^2.8",
        "michaloravec/laravel-paginateroute": "^1.0",
        "openai-php/laravel": "^0.10|^0.18",
        "owenvoke/blade-fontawesome": "^2.8",
        "saade/filament-adjacency-list": "^4.0",
        "silber/page-cache": "^1.0.9",
        "spatie/laravel-activitylog": "^4.0",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1",
        "staudenmeir/eloquent-has-many-deep": "^1.1",
        "staudenmeir/eloquent-json-relations": "^1.1",
        "stijnvanouplines/blade-country-flags": "^1.0",
        "symfony/filesystem": "^7.2",
        "symfony/process": "^7.2",
        "symplify/monorepo-builder": "^10.3.3",
        "tanmuhittin/laravel-google-translate": "^2.4",
        "tapp/filament-authentication-log": "^4.0",
        "torann/geoip": "^3.0",
        "voku/html-min": "^4.5",
        "wildside/userstamps": "^2.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "*",
        "calebdw/larastan-livewire": "^2.4",
        "canvural/larastan-strict-rules": "^3.0",
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.3",
        "laravel/pint": "^1.25.0",
        "mrpunyapal/peststan": "^0.1.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.3",
        "orchestra/testbench": "*",
        "pestphp/pest": "^3.0|^4.1",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "pestphp/pest-plugin-type-coverage": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-beberlei-assert": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0",
        "sinnbeck/laravel-dom-assertions": "^2.7",
        "soyhuce/phpstan-extension": "^1.1|^2.1",
        "spatie/laravel-ray": "^1.36"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Address\\": "packages/address/src",
            "Capell\\Assistant\\": "packages/assistant/src",
            "Capell\\Blog\\": "packages/blog/src",
            "Capell\\Mosaic\\": "packages/mosaic/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Address\\Database\\Factories\\": "packages/address/database/factories",
            "Capell\\Assistant\\Database\\Factories\\": "packages/assistant/database/factories",
            "Capell\\Blog\\Database\\Factories\\": "packages/blog/database/factories",
            "Capell\\Mosaic\\Database\\Factories\\": "packages/mosaic/database/factories",
            "Capell\\Tests\\": "tests/src"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "process-timeout": 0,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
