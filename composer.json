{
    "name": "capell-app/navigation",
    "description": "Site- and language-scoped navigation menus for Capell: visual menu builder, page & link items, nested dropdowns, active-state rendering, publish scheduling, and multi-site replication.",
    "keywords": [
        "capell",
        "navigation",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/navigation",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "capell.app26@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "capell-app/admin": "^0.0 || 0.0.x-dev",
        "capell-app/core": "^0.0 || 0.0.x-dev",
        "capell-app/frontend": "^0.0 || 0.0.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Navigation\\": "src/",
            "Capell\\Navigation\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Navigation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Navigation\\Providers\\NavigationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/navigation"
    }
}
