{
    "name": "capell-app/capell-packages",
    "description": "Capell 4 Packages",
    "home": "https://capell.app",
    "type": "library",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "rector": "rector",
        "lint": "pint --diff=4.x --parallel",
        "analyze": "phpstan analyse --memory-limit=-1 --configuration=phpstan.neon",
        "prettier": "npx prettier --write \"packages/**/*.{css,js,yml,json,md,blade.php}\"",
        "preflight": [
            "@prettier",
            "@rector",
            "@lint",
            "@analyze"
        ],
        "test:unit": "php -d memory_limit=-1 vendor/bin/pest --colors=always --parallel --configuration=phpunit.xml",
        "test": [
            "@test:unit"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "package",
            "package": {
                "name": "capell-app/admin",
                "version": "4.x-dev",
                "source": {
                    "type": "git",
                    "url": "https://github.com/capell-app/capell.git",
                    "reference": "4.x"
                },
                "autoload": {
                    "psr-4": {
                        "Capell\\Admin\\": "packages/admin/src"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Capell\\Admin\\AdminServiceProvider"
                        ]
                    }
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "capell-app/core",
                "version": "4.x-dev",
                "source": {
                    "type": "git",
                    "url": "https://github.com/capell-app/capell.git",
                    "reference": "4.x"
                },
                "autoload": {
                    "psr-4": {
                        "Capell\\Core\\": "packages/core/src",
                        "Capell\\Core\\Database\\Factories\\": "packages/core/database/factories"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Capell\\Core\\CapellServiceProvider"
                        ]
                    }
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "capell-app/frontend",
                "version": "4.x-dev",
                "source": {
                    "type": "git",
                    "url": "https://github.com/capell-app/capell.git",
                    "reference": "4.x"
                },
                "autoload": {
                    "psr-4": {
                        "Capell\\Frontend\\": "packages/frontend/src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Capell\\Frontend\\FrontendServiceProvider"
                        ]
                    }
                }
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/capell"
        },
        {
            "type": "vcs",
            "url": "https://github.com/howdu/filament-title-with-slug"
        },
        {
            "type": "vcs",
            "url": "https://github.com/lara-zeus/translatable"
        },
        {
            "type": "vcs",
            "url": "https://github.com/TappNetwork/activitylog"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-fileinfo": "*",
        "ext-intl": "*",
        "ext-simplexml": "*",
        "amidesfahani/filament-tinyeditor": "^4.0",
        "awcodes/filament-badgeable-column": "^3.0",
        "awobaz/compoships": "^2.3",
        "bezhansalleh/filament-shield": "^4.0",
        "bkwld/cloner": "^3.11",
        "blade-ui-kit/blade-heroicons": "^2.5",
        "blendbyte/filament-title-with-slug": "fila4",
        "capell-app/admin": "4.x-dev",
        "capell-app/core": "4.x-dev",
        "capell-app/frontend": "4.x-dev",
        "codewithdennis/filament-select-tree": "^4.0",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0",
        "filament/spatie-laravel-settings-plugin": "^4.0",
        "filament/spatie-laravel-tags-plugin": "^4.0",
        "guava/filament-icon-picker": "^3.0",
        "guzzlehttp/guzzle": "^7.5",
        "howdu/filament-record-switcher": "^2.0",
        "icamys/php-sitemap-generator": "^4.4.1",
        "kalnoy/nestedset": "^6.0.2",
        "lara-zeus/spatie-translatable": "^1.0",
        "laravel/framework": "^11.0|^12.0",
        "laravel/prompts": "^0.3",
        "lorisleiva/laravel-actions": "^2.8",
        "michaloravec/laravel-paginateroute": "^1.0",
        "oddvalue/laravel-drafts": "^1.0|^2.0",
        "openai-php/laravel": "*",
        "owenvoke/blade-fontawesome": "^2.8",
        "rmsramos/activitylog": "filament4",
        "saade/filament-adjacency-list": "4.x-dev",
        "silber/page-cache": "^1.0.9",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1",
        "staudenmeir/eloquent-has-many-deep": "^1.1",
        "staudenmeir/eloquent-json-relations": "^1.1",
        "stijnvanouplines/blade-country-flags": "^1.0|dev-l12-compatibility",
        "symfony/filesystem": "^7.2",
        "symfony/process": "^7.2",
        "symplify/monorepo-builder": "^10.3.3",
        "tanmuhittin/laravel-google-translate": "^2.4",
        "tapp/filament-authentication-log": "^4.0",
        "torann/geoip": "^3.0",
        "voku/html-min": "^4.5",
        "wildside/userstamps": "^2.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "*",
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.24.1",
        "filament/upgrade": "^4.0",
        "larastan/larastan": "^3.7.1",
        "laravel/pail": "^1.2.3",
        "laravel/pint": "^1.25.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.2",
        "orchestra/testbench": "*",
        "pestphp/pest": "^3.0|^4.1",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "pestphp/pest-plugin-type-coverage": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.36"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Address\\": "packages/address/src",
            "Capell\\Blog\\": "packages/blog/src",
            "Capell\\Hero\\": "packages/hero/src",
            "Capell\\Layout\\": "packages/layout/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Address\\Database\\Factories\\": "packages/address/database/factories",
            "Capell\\Blog\\Database\\Factories\\": "packages/blog/database/factories",
            "Capell\\Layout\\Database\\Factories\\": "packages/layout/database/factories",
            "Capell\\Tests\\": "tests/src"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "process-timeout": 0,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Address\\AddressServiceProvider",
                "Capell\\Blog\\BlogServiceProvider",
                "Capell\\Hero\\HeroServiceProvider",
                "Capell\\Layout\\LayoutServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
