{
    "name": "capell-app/navigation",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Foundation",
    "tier": "free",
    "bundle": "foundation",
    "description": "Navigation adds site and language scoped navigation trees, page navigation fields, sync actions, and frontend loading support.",
    "contexts": ["admin", "frontend", "console"],
    "requires": ["capell-app/core", "capell-app/admin", "capell-app/frontend"],
    "providers": {
        "shared": ["Capell\\Navigation\\Providers\\NavigationServiceProvider"]
    },
    "commands": {
        "setup": "capell:navigation-setup",
        "setupParams": ["sites"],
        "demo": "capell:navigation-demo",
        "demoParams": ["sites", "languages"]
    }
}
