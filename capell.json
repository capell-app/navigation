{
    "manifest-version": 3,
    "name": "capell-app/navigation",
    "slug": "navigation",
    "displayName": "Navigation",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Site- and language-scoped navigation menus for Capell: visual menu builder, page & link items, nested dropdowns, active-state rendering, publish scheduling, and multi-site replication.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\Navigation",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "supports": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\Navigation\\Providers\\NavigationServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [
        {
            "type": "admin-resource",
            "class": "Capell\\Navigation\\Manifest\\NavigationAdminResourceContribution",
            "resourceClass": "Capell\\Navigation\\Filament\\Resources\\Navigations\\NavigationResource"
        },
        {
            "type": "schema-extender",
            "class": "Capell\\Navigation\\Manifest\\NavigationSchemaExtendersContribution",
            "extenderClasses": [
                "Capell\\Navigation\\Filament\\Extenders\\NavigationPageSchemaExtender",
                "Capell\\Navigation\\Filament\\Extenders\\NavigationSiteExtender"
            ]
        },
        {
            "type": "configurator",
            "class": "Capell\\Navigation\\Manifest\\NavigationConfiguratorContribution",
            "configuratorClasses": [
                "Capell\\Navigation\\Filament\\Configurators\\Navigations\\DefaultNavigationConfigurator"
            ]
        },
        {
            "type": "page-type",
            "class": "Capell\\Navigation\\Manifest\\NavigationPageTypeContribution",
            "name": "navigation",
            "modelClass": "Capell\\Navigation\\Models\\Navigation"
        },
        {
            "type": "model",
            "class": "Capell\\Navigation\\Manifest\\NavigationModelsContribution",
            "modelClass": "Capell\\Navigation\\Models\\Navigation"
        },
        {
            "type": "migration",
            "class": "Capell\\Navigation\\Manifest\\NavigationMigrationsContribution",
            "tables": ["navigations", "navigation_page_references"]
        },
        {
            "type": "route",
            "class": "Capell\\Navigation\\Manifest\\NavigationFrontendRouteContribution",
            "routeNames": ["capell-navigation.children"]
        },
        {
            "type": "frontend-component",
            "class": "Capell\\Navigation\\Manifest\\NavigationFrontendComponentsContribution",
            "componentClasses": [
                "Capell\\Navigation\\View\\Components\\Menu",
                "Capell\\Navigation\\View\\Components\\Breadcrumbs",
                "Capell\\Navigation\\View\\Components\\Header\\MainNavigation"
            ]
        },
        {
            "type": "configurator",
            "class": "Capell\\Navigation\\Manifest\\NavigationFrontendRuntimeContribution",
            "contributorClass": "Capell\\Navigation\\Support\\NavigationFrontendRuntimeManifestContributor"
        },
        {
            "type": "render-hook",
            "class": "Capell\\Navigation\\Manifest\\NavigationRenderHookContribution",
            "hookClass": "Capell\\Navigation\\Support\\RenderHooks\\RegisterFoundationHeaderNavigationHook",
            "location": "headerAfter",
            "keys": [
                "foundation-header-navigation-default",
                "foundation-header-navigation-foundation"
            ],
            "cacheSafe": true
        },
        {
            "type": "configurator",
            "class": "Capell\\Navigation\\Manifest\\NavigationContentGraphContribution",
            "extractorClass": "Capell\\Navigation\\Support\\ContentGraph\\NavigationContentGraphExtractor"
        },
        {
            "type": "console-command",
            "class": "Capell\\Navigation\\Manifest\\NavigationConsoleCommandsContribution",
            "commands": [
                "capell:navigation-setup",
                "capell:navigation-demo"
            ],
            "commandClasses": [
                "Capell\\Navigation\\Console\\Commands\\SetupCommand",
                "Capell\\Navigation\\Console\\Commands\\DemoCommand"
            ]
        },
        {
            "type": "health-check",
            "class": "Capell\\Navigation\\Manifest\\NavigationHealthContribution",
            "checkClass": "Capell\\Navigation\\Health\\NavigationHealthCheck"
        }
    ],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": ["navigations", "navigation_page_references"]
    },
    "commands": {
        "install": null,
        "setup": "capell:navigation-setup",
        "setupParams": ["sites"],
        "demo": "capell:navigation-demo",
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "navigation-menu-builder",
        "navigation-handle-registry",
        "navigation-mega-menus",
        "navigation-page-field",
        "navigation-render-model",
        "navigation-site-replication",
        "navigation-external-links",
        "navigation-active-state-modes",
        "navigation-breadcrumbs",
        "navigation-conditional-visibility"
    ],
    "security": {
        "riskTier": "standard",
        "publicSurface": {
            "routeNames": ["capell-navigation.children"],
            "auth": "public",
            "csrfExemptRoutes": [],
            "signedRoutes": [],
            "tokenizedRoutes": [],
            "webhookRoutes": [],
            "throttledRoutes": []
        },
        "sensitiveData": {
            "encryptedFields": [],
            "hashedTokenFields": [],
            "redactedOutputClasses": [],
            "plaintextJustifications": []
        },
        "publicOutput": {
            "cacheSafe": true,
            "forbidAuthoringSurface": true,
            "forbidSecrets": true,
            "forbidPublicBladeQueries": true
        },
        "externalHttpClients": {
            "requiresTimeouts": false,
            "requiresSecretRedaction": false,
            "clients": []
        },
        "adminSurface": {
            "authorization": "policies",
            "permissions": []
        }
    },
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["navigation"],
        "cacheSafety": {
            "cacheable": true,
            "variesBy": ["site", "locale", "page", "domain", "guest"],
            "sensitiveOutput": false,
            "invalidationSources": [
                {
                    "model": "Capell\\Navigation\\Models\\Navigation",
                    "events": ["saved", "deleted", "restored"]
                },
                {
                    "model": "Capell\\Core\\Models\\Page",
                    "events": ["updated"]
                },
                {
                    "model": "Capell\\Core\\Models\\Site",
                    "events": ["replicated"]
                }
            ],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "navigation.package-health",
            "label": "Navigation package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\Navigation\\Health\\NavigationHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Build and manage multilingual, per-site menus visually — link to any page or URL, nest dropdowns, and render them in your theme with one tag. Active-state, publish windows, and site cloning included.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Navigation marketplace card showing editor-managed site menus",
                "caption": "Navigation gives Capell editors a visual menu builder for site and language scoped menus"
            },
            {
                "path": "docs/screenshots/create-edit-navigation-form.png",
                "alt": "Create and edit navigation form with links, page references, and nested items",
                "caption": "Build nested menus from page references, links, and headings"
            },
            {
                "path": "docs/screenshots/create-edit-navigation-form-dark.png",
                "alt": "Create and edit navigation form in dark mode",
                "caption": "Build nested menus from the dark-mode create and edit form"
            },
            {
                "path": "docs/screenshots/site-relation-manager-for-navigations.png",
                "alt": "Site relation manager listing navigations for a site",
                "caption": "Manage a site's scoped navigations directly from the site edit surface"
            },
            {
                "path": "docs/screenshots/site-relation-manager-for-navigations-dark.png",
                "alt": "Site relation manager for navigations in dark mode",
                "caption": "Manage site-scoped navigations from the dark-mode site relation manager"
            }
        ],
        "categories": ["admin", "console", "foundation", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": []
    }
}
