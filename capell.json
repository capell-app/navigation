{
    "manifest-version": 3,
    "name": "capell-app/navigation",
    "slug": "navigation",
    "displayName": "Navigation",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Site- and language-scoped navigation menus for Capell: visual menu builder, page & link items, nested dropdowns, active-state rendering, publish scheduling, and multi-site replication.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\Navigation",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "supports": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\Navigation\\Providers\\NavigationServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": "capell:navigation-setup",
        "setupParams": ["sites"],
        "demo": "capell:navigation-demo",
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "navigation-menu-builder",
        "navigation-page-field",
        "navigation-render-model",
        "navigation-site-replication"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["navigation"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [
                {
                    "model": "Capell\\Navigation\\Models\\Navigation",
                    "events": ["saved", "deleted", "restored"]
                },
                {
                    "model": "Capell\\Core\\Models\\Page",
                    "events": ["updated"]
                },
                {
                    "model": "Capell\\Core\\Models\\Site",
                    "events": ["replicated"]
                }
            ],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "navigation.package-health",
            "label": "Navigation package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\Navigation\\Health\\NavigationHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Build and manage multilingual, per-site menus visually — link to any page or URL, nest dropdowns, and render them in your theme with one tag. Active-state, publish windows, and site cloning included.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Navigation extension preview image",
                "caption": "Navigation extension preview"
            },
            {
                "path": "docs/assets/marketplace/hero-desktop.jpg",
                "alt": "Navigation hero banner on desktop",
                "caption": "Navigation hero (desktop)"
            },
            {
                "path": "docs/assets/marketplace/hero-mobile.jpg",
                "alt": "Navigation hero banner on mobile",
                "caption": "Navigation hero (mobile)"
            },
            {
                "path": "docs/screenshots/navigation-admin-index.png",
                "alt": "Navigation admin index listing site navigations and their scope",
                "caption": "Navigation admin index"
            },
            {
                "path": "docs/screenshots/navigation-admin-index-dark.png",
                "alt": "Navigation admin index in dark mode",
                "caption": "Navigation admin index (dark)"
            },
            {
                "path": "docs/screenshots/create-edit-navigation-form.png",
                "alt": "Create and edit navigation form with links, page references, and nested items",
                "caption": "Create/edit navigation form"
            },
            {
                "path": "docs/screenshots/create-edit-navigation-form-dark.png",
                "alt": "Create and edit navigation form in dark mode",
                "caption": "Create/edit navigation form (dark)"
            },
            {
                "path": "docs/screenshots/site-relation-manager-for-navigations.png",
                "alt": "Site relation manager listing navigations for a site",
                "caption": "Site relation manager for navigations"
            },
            {
                "path": "docs/screenshots/site-relation-manager-for-navigations-dark.png",
                "alt": "Site relation manager for navigations in dark mode",
                "caption": "Site relation manager for navigations (dark)"
            },
            {
                "path": "docs/screenshots/page-form-navigation-tab.png",
                "alt": "Page form navigation tab showing which menus reference the page",
                "caption": "Page form navigation tab"
            },
            {
                "path": "docs/screenshots/page-form-navigation-tab-dark.png",
                "alt": "Page form navigation tab in dark mode",
                "caption": "Page form navigation tab (dark)"
            },
            {
                "path": "docs/screenshots/frontend-menu-output.png",
                "alt": "Frontend menu output rendered for an anonymous visitor",
                "caption": "Frontend menu output"
            },
            {
                "path": "docs/screenshots/frontend-menu-output-dark.png",
                "alt": "Frontend menu output in dark mode",
                "caption": "Frontend menu output (dark)"
            }
        ],
        "categories": ["admin", "console", "foundation", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-resource",
            "configurator",
            "migration",
            "model",
            "page-type",
            "route",
            "schema-extender"
        ]
    }
}
