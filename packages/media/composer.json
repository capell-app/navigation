{
    "name": "capell-app/media",
    "description": "Media library admin UI for Capell",
    "keywords": [
        "capell",
        "media",
        "laravel",
        "filamentphp"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "filament/spatie-laravel-media-library-plugin": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Media\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Media\\Providers\\MediaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
