{
    "name": "capell-app/authentication-log",
    "description": "Authentication log for Capell",
    "keywords": [
        "capell",
        "authentication-log",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/authentication-log",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "rappasoft/laravel-authentication-log": "^6.0|^5.0",
        "tapp/filament-authentication-log": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\AuthenticationLog\\": "src/",
            "Capell\\AuthenticationLog\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\AuthenticationLog\\Providers\\AuthenticationLogServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
