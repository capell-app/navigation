{
    "name": "capell-app/developer-tools",
    "description": "Developer and operational diagnostics for Capell CMS.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Capell\\DeveloperTools\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\DeveloperTools\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\DeveloperTools\\Providers\\DeveloperToolsServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "require": {
        "php": "^8.2",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5"
    }
}
