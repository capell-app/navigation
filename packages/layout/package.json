{
    "private": true,
    "description": "Capell Pro",
    "author": "capell",
    "type": "module",
    "scripts": {
        "dev": "npm-run-all --parallel dev:*",
        "dev:vite": "vite",
        "dev:filament-styles": "vite --config vite.filament.config.js",
        "build": "npm-run-all build:*",
        "build:vite": "vite build",
        "build:filament-styles": "vite build --config vite.filament.config.js",
        "filament-purge": "filament-purge -i publishes/build/capell-layout-filament.css -o publishes/build/capell-layout-filament.css -v 3.x"
    },
    "devDependencies": {
        "@alpinejs/focus": "^3.11.1",
        "@alpinejs/intersect": "^3.12.0",
        "@alpinejs/sort": "^3.14.8",
        "@awcodes/filament-plugin-purge": "^1.1.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/typography": "^0.5.9",
        "@tailwindcss/vite": "^4.0.13",
        "alpinejs": "^3.11.1",
        "autoprefixer": "^10.4.13",
        "laravel-vite-plugin": "^1.2.0",
        "npm-run-all": "^4.1.5",
        "swiper": "^11.1.14",
        "tailwindcss-v3": "npm:tailwindcss@^3.4.17",
        "tailwindcss": "^4.1.11",
        "tippy.js": "^6.3.7",
        "vanilla-lazyload": "^19.1.3",
        "vite": "^6.2.1",
        "wheel-gestures": "^2.2.5"
    }
}
