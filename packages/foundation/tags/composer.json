{
    "name": "capell-app/tags",
    "description": "Tags for Capell",
    "keywords": [
        "capell",
        "tags",
        "laravel",
        "filamentphp"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/navigation": "*",
        "capell-app/workspaces": "*",
        "filament/spatie-laravel-tags-plugin": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Tags\\": "src/",
            "Capell\\Tags\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Tags\\Providers\\TagsServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
