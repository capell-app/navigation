{
    "name": "capell-app/frontend-toolbar",
    "description": "Admin toolbar and beacon for Capell frontend",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/frontend": "*",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Toolbar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Toolbar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Toolbar\\Providers\\ToolbarServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
