{
    "name": "capell-app/blog",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Foundation",
    "tier": "free",
    "bundle": "foundation",
    "contexts": ["admin", "frontend", "console"],
    "requires": [
        "capell-app/core",
        "capell-app/admin",
        "capell-app/frontend",
        "capell-app/mosaic",
        "capell-app/tags"
    ],
    "providers": {
        "shared": ["Capell\\Blog\\Providers\\BlogServiceProvider"],
        "admin": ["Capell\\Blog\\Providers\\AdminServiceProvider"],
        "frontend": ["Capell\\Blog\\Providers\\FrontendServiceProvider"],
        "console": ["Capell\\Blog\\Providers\\ConsoleServiceProvider"]
    },
    "commands": {
        "install": "capell:blog-install",
        "setup": "capell:blog-setup",
        "setupParams": ["sites", "languages"],
        "demo": "capell:blog-demo",
        "demoParams": ["sites", "user", "limit"]
    }
}
