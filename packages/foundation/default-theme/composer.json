{
    "name": "capell-app/default-theme",
    "description": "Capell default theme — ships the standard Tailwind asset pipeline, Blade directives, URL generator, and SVG media component.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/frontend": "*",
        "spatie/laravel-package-tools": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\DefaultTheme\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\DefaultTheme\\Providers\\DefaultThemeServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
