{
    "name": "capell-app/html-minify",
    "description": "HTML minification for Capell frontend rendering and page cache writes.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/frontend": "self.version",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.15",
        "voku/html-min": "^4.5"
    },
    "autoload": {
        "psr-4": {
            "Capell\\HtmlMinify\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\HtmlMinify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\HtmlMinify\\Providers\\HtmlMinifyServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
