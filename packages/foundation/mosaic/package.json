{
    "private": true,
    "description": "Capell Layout",
    "author": "capell",
    "type": "module",
    "scripts": {
        "dev": "npm-run-all --parallel dev:*",
        "dev:vite": "vite",
        "dev:vite-filament": "vite --config vite.filament.config.js",
        "build": "npm-run-all build:*",
        "build:vite": "vite build",
        "build:vite-filament": "vite build --config vite.filament.config.js",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@alpinejs/focus": "^3.11.1",
        "@alpinejs/intersect": "^3.12.0",
        "@alpinejs/sort": "^3.14.8",
        "@awcodes/alpine-floating-ui": "^3.5.0",
        "@ryangjchandler/alpine-tooltip": "^2.0.1",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/typography": "^0.5.9",
        "@tailwindcss/vite": "^4.0.13",
        "alpinejs": "^3.11.1",
        "autoprefixer": "^10.4.13",
        "jsdom": "^26.1.0",
        "laravel-vite-plugin": "^3.0",
        "npm-run-all": "^4.1.5",
        "swiper": "^12.1.3",
        "tailwindcss": "^4.0.14",
        "tippy.js": "^6.3.7",
        "vanilla-lazyload": "^19.1.3",
        "vite": "^8.0",
        "vitest": "^3.2.4",
        "wheel-gestures": "^2.2.5"
    }
}
