{
    "$schema": "https://marketplace.capell.app/schema/plugin.v1.json",
    "name": "acme/super-widget",
    "title": "Super Widget",
    "slug": "super-widget",
    "version": "1.2.0",
    "description": "Lead capture forms with personalization",
    "long_description_file": "README.md",
    "vendor": "acme",
    "license_model": "paid_subscription",
    "price": { "monthly": 900, "yearly": 9000, "currency": "usd" },
    "trial_days": 7,
    "categories": ["widgets", "marketing"],
    "tags": ["forms", "lead-capture"],
    "compatibility": {
        "capell": "^4.0 || ^5.0",
        "php": "^8.2"
    },
    "capabilities": [
        "db_schema_changes",
        "http_outbound:api.acme.com",
        "admin_pages",
        "frontend_routes"
    ],
    "kind": "full",
    "entrypoint": "Acme\\SuperWidget\\SuperWidgetPlugin",
    "requires": ["capell-app/mosaic: ^1.0"],
    "icon": "assets/icon.svg",
    "screenshots": ["assets/screenshot-1.png", "assets/screenshot-2.png"],
    "support": {
        "email": "support@acme.com",
        "docs_url": "https://docs.acme.com/super-widget"
    },
    "hooks": {
        "install": "Acme\\SuperWidget\\Hooks\\Install",
        "uninstall": "Acme\\SuperWidget\\Hooks\\Uninstall",
        "upgrade": "Acme\\SuperWidget\\Hooks\\Upgrade"
    }
}
