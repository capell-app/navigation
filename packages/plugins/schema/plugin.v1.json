{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://marketplace.capell.app/schema/plugin.v1.json",
    "title": "Capell Plugin Manifest",
    "type": "object",
    "required": [
        "name",
        "title",
        "slug",
        "version",
        "description",
        "vendor",
        "license_model",
        "compatibility",
        "capabilities",
        "kind",
        "entrypoint"
    ],
    "properties": {
        "$schema": { "type": "string", "format": "uri" },
        "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z\\-.]+)?(?:\\+[0-9A-Za-z\\-.]+)?$" },
        "description": { "type": "string", "minLength": 10, "maxLength": 180 },
        "long_description_file": { "type": "string" },
        "vendor": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "license_model": { "enum": ["free", "paid_one_time", "paid_subscription"] },
        "price": {
            "type": "object",
            "properties": {
                "monthly": { "type": "integer", "minimum": 0 },
                "yearly": { "type": "integer", "minimum": 0 },
                "once": { "type": "integer", "minimum": 0 },
                "currency": { "type": "string", "pattern": "^[a-z]{3}$" }
            },
            "required": ["currency"],
            "additionalProperties": false
        },
        "trial_days": { "type": "integer", "minimum": 0, "maximum": 30 },
        "categories": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 5
        },
        "tags": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 10
        },
        "compatibility": {
            "type": "object",
            "required": ["capell", "php"],
            "properties": {
                "capell": { "type": "string" },
                "php": { "type": "string" }
            },
            "additionalProperties": false
        },
        "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
        },
        "kind": { "enum": ["theme", "page_type", "widget", "integration", "content_type", "full"] },
        "entrypoint": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9_]*(?:\\\\[A-Z][A-Za-z0-9_]*)*$" },
        "requires": {
            "type": "array",
            "items": { "type": "string" }
        },
        "icon": { "type": "string" },
        "screenshots": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 6
        },
        "support": {
            "type": "object",
            "properties": {
                "email": { "type": "string", "format": "email" },
                "docs_url": { "type": "string", "format": "uri" },
                "support_url": { "type": "string", "format": "uri" }
            },
            "additionalProperties": false
        },
        "hooks": {
            "type": "object",
            "properties": {
                "install": { "type": "string" },
                "uninstall": { "type": "string" },
                "upgrade": { "type": "string" }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false,
    "allOf": [
        {
            "if": { "properties": { "license_model": { "const": "free" } } },
            "then": { "not": { "required": ["price"] } }
        },
        {
            "if": { "properties": { "license_model": { "enum": ["paid_one_time", "paid_subscription"] } } },
            "then": { "required": ["price"] }
        }
    ]
}
