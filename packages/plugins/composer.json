{
    "name": "capell-app/plugins",
    "description": "Plugins marketplace for Capell",
    "keywords": [
        "capell",
        "plugins",
        "marketplace",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/plugins",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "spatie/laravel-data": "^4.5",
        "opis/json-schema": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Plugins\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Plugins\\Providers\\PluginsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
