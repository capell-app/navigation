{
    "name": "capell-app/blog",
    "description": "Blog for Capell",
    "keywords": [
        "capell",
        "blog",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/blog",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/frontend": "*",
        "capell-app/tags": "*"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Blog\\": "src/",
            "Capell\\Blog\\Database\\Factories\\": "packages/blog/database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Blog\\Providers\\BlogServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
