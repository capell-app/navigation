{
    "name": "capell-app/themes-admin",
    "description": "Capell themes admin schemas and Filament integration",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "capell-app/themes-core": "*",
        "filament/filament": "^4.7|^5.2",
        "spatie/laravel-package-tools": "^1.14"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Themes\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Themes\\Admin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Themes\\Admin\\ThemesAdminServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
